# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.cache

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

venv

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma
/prisma/dev.db
/prisma/dev.db-journal

/src/generated/prisma

# generated at build time by scripts/buildBlogIndex.ts (runtime falls back to a
# live corpus walk when absent, so it never needs to be committed)
/src/lib/generated/blogPostsIndex.json

*.log